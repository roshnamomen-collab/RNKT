rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(data) {
      return isSignedIn() && data.authorId == request.auth.uid;
    }

    // --- Validation Blueprints ---

    function isValidSentence(data) {
      return data.keys().hasAll(['bookId', 'itemId', 'ottoman', 'sorani', 'turkish', 'wordMap', 'authorId', 'createdAt'])
        && data.bookId is string && data.bookId.size() <= 128
        && data.itemId is string && data.itemId.size() <= 128
        && data.ottoman is list && data.ottoman.size() <= 1000
        && data.sorani is list && data.sorani.size() <= 1000
        && data.turkish is list && data.turkish.size() <= 1000
        && data.wordMap is list && data.wordMap.size() <= 1000
        && data.authorId is string && data.authorId.size() <= 128;
    }

    // --- Collections ---

    match /sentences/{sentenceId} {
      allow read: if true;

      allow create: if isSignedIn()
        && isValidId(sentenceId)
        && isValidSentence(incoming());

      allow update: if isSignedIn()
        && isValidId(sentenceId)
        && isValidSentence(incoming())
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['ottoman', 'sorani', 'turkish', 'wordMap', 'bookId', 'itemId', 'updatedAt'])
        );

      allow delete: if isSignedIn();
    }

    match /test/{document=**} {
      allow read, write: if true;
    }
  }
}
