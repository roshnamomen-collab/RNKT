rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(data) {
      return isSignedIn() && data.authorId == request.auth.uid;
    }

    // --- Validation Blueprints ---

    function isValidSentence(data) {
      return data.keys().hasAll(['ottoman', 'sorani', 'turkish', 'wordMap', 'authorId', 'createdAt'])
        && data.keys().size() == 6
        && data.ottoman is list && data.ottoman.size() <= 500
        && data.sorani is list && data.sorani.size() <= 500
        && data.turkish is list && data.turkish.size() <= 500
        && data.wordMap is list && data.wordMap.size() <= 500
        && data.authorId is string && data.authorId.size() <= 128;
    }

    // --- Collections ---

    match /sentences/{sentenceId} {
      // 8. Secure List Queries: Explicitly allow public reading as this is an educational tool.
      // If we wanted private, we'd add: && resource.data.authorId == request.auth.uid
      allow list: if true; 
      allow get: if true;

      allow create: if isSignedIn()
        && isValidId(sentenceId)
        && isValidSentence(incoming())
        && incoming().authorId == request.auth.uid
        && incoming().createdAt == request.time;

      allow update: if isSignedIn()
        && isValidId(sentenceId)
        && isOwner(existing())
        && isValidSentence(incoming())
        && incoming().authorId == existing().authorId
        && incoming().createdAt == existing().createdAt
        && (
          // Action: Edit content
          incoming().diff(existing()).affectedKeys().hasOnly(['ottoman', 'sorani', 'turkish', 'wordMap'])
        );

      allow delete: if isSignedIn() && isOwner(existing());
    }
  }
}
